rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function accessDoc() {
      return get(/databases/$(database)/documents/config/access);
    }

    function uidInList(list) {
      return list is list && request.auth.uid in list;
    }

    function canWriteSetsData() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/config/access) &&
          (uidInList(accessDoc().data.adminUids) ||
           uidInList(accessDoc().data.editorUids)))
      );
    }

    function canManageAccessDoc() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/config/access) &&
          uidInList(accessDoc().data.adminUids))
      );
    }

    match /config/access {
      allow read: if request.auth != null;
      allow create: if canManageAccessDoc();
      allow update: if canManageAccessDoc();
    }

    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /sets/{setId} {
      allow read: if request.auth != null;
      allow write: if canWriteSetsData();
    }
  }
}
